//
// adcA1ISR - ADC A Interrupt 1 ISR
//
__interrupt void adcA1ISR(void)
{
#if 0
    int i;
    float avgSquare, rms;
    unsigned long curr_square;
    unsigned long volt_square;
    signed long j;
#endif
    /*
     * ADC Conversion for the Input, Output and Ground Current
     */
    wAdcCurrBuff[0] = (signed int)(ADC_readResult(ADCARESULT_BASE, ADC_SOC_NUMBER0) - 2020); // OP Current R Phase
    wAdcCurrBuff[1] = (signed int)(ADC_readResult(ADCARESULT_BASE, ADC_SOC_NUMBER1) - offset_value); // OP Current Y Phase
    wAdcCurrBuff[2] = (signed int)(ADC_readResult(ADCARESULT_BASE, ADC_SOC_NUMBER2) - offset_value); // OP Current B Phase
    wAdcCurrBuff[3] = (signed int)(ADC_readResult(ADCARESULT_BASE, ADC_SOC_NUMBER3) - 2010); // IP Current R Phase
    wAdcCurrBuff[4] = (signed int)(ADC_readResult(ADCARESULT_BASE, ADC_SOC_NUMBER4) - offset_value); // IP Current Y Phase
    wAdcCurrBuff[5] = (signed int)(ADC_readResult(ADCARESULT_BASE, ADC_SOC_NUMBER5) - offset_value); // IP Current B Phase
    wAdcCurrBuff[6] = (signed int)(ADC_readResult(ADCARESULT_BASE, ADC_SOC_NUMBER6) - offset_value); // GND Current

    /*
     * ADC Conversion for the Input and Output Voltage
     * In input we are measuring as Line to Line and we need to calculate for Line to Neutral
     * In output we are measuring as Line to Neutral and we need to calculate for Line to Line
     */
   // wAdcVoltBuff[0] = (signed int)(ADC_readResult(ADCARESULT_BASE, ADC_SOC_NUMBER7) - offset_value);
   wAdcVoltBuff[0] = (signed int)(ADC_readResult(ADCARESULT_BASE, ADC_SOC_NUMBER7) - offset_value); // OP Voltage RN Phase
    wAdcVoltBuff[1] = (signed int)(ADC_readResult(ADCARESULT_BASE, ADC_SOC_NUMBER8) - offset_value); // OP Voltage YN Phase
    wAdcVoltBuff[2] = (signed int)(ADC_readResult(ADCARESULT_BASE, ADC_SOC_NUMBER9) - offset_value); // OP Voltage BN Phase
    wAdcVoltBuff[3] = (signed int)(ADC_readResult(ADCARESULT_BASE, ADC_SOC_NUMBER10) - offset_value); // IP Voltage RY Phase
    wAdcVoltBuff[4] = (signed int)(ADC_readResult(ADCERESULT_BASE, ADC_SOC_NUMBER0) - offset_value); // IP Voltage YB Phase
    wAdcVoltBuff[5] = (signed int)(ADC_readResult(ADCARESULT_BASE, ADC_SOC_NUMBER11) - offset_value); // IP Voltage BR Phase

    /*
     * For each channel, square the result and accumulate it.
     */
    for(i = 0; i < PHASE_CURR; i++)
    {
        curr_square = (unsigned long)wAdcCurrBuff[i] * (unsigned long)wAdcCurrBuff[i];
        dwSumPhaseCurr[i] += curr_square;
    }

    for(i = 0; i < PHASE_VOLT; i++)
    {
        volt_square = (unsigned long)wAdcVoltBuff[i] * (unsigned long)wAdcVoltBuff[i];
        dwSumPhaseVolt[i] += volt_square;
    }

    /*
     * Added for the KW Calculation for the input Parameter
     */
    j = ((long)wAdcVoltBuff[3] * (long)wAdcCurrBuff[3]);
    dwSumPhaseWatt[0] += j; // Input KW R Phase
    j = 0;

    j = ((long)wAdcVoltBuff[4] * (long)wAdcCurrBuff[4]);
    dwSumPhaseWatt[1] += j; // Input KW Y Phase
    j = 0;

    j = ((long)wAdcVoltBuff[5] * (long)wAdcCurrBuff[5]);
    dwSumPhaseWatt[2] += j; // Input KW B Phase
    j = 0;

    //
    // Increment the sample counter.
    //
    sampleCount++;

    //
    // Once 100 samples have been collected, compute the RMS for each channel.
    //
    if(sampleCount >= SAMPLE_COUNT_THRESHOLD)
    {
        /*
         * RMS calculation of the input, output and GND current
         */
        avgSquare = (float)dwSumPhaseCurr[0] / (float)SAMPLE_COUNT_THRESHOLD;
        rms = sqrtf(avgSquare) * calib_curr / 10000;
        secondary.RMS_Curr_Phase_R = (unsigned int)rms;
        dwSumPhaseCurr[0] = 0;

        avgSquare = (float)dwSumPhaseCurr[1] / (float)SAMPLE_COUNT_THRESHOLD;
        rms = sqrtf(avgSquare) * calib_curr / 10000;
        secondary.RMS_Curr_Phase_Y = (unsigned int)rms;
        dwSumPhaseCurr[1] = 0;

        avgSquare = (float)dwSumPhaseCurr[2] / (float)SAMPLE_COUNT_THRESHOLD;
        rms = sqrtf(avgSquare) * calib_curr / 10000;
        secondary.RMS_Curr_Phase_B = (unsigned int)rms;
        dwSumPhaseCurr[2] = 0;

        avgSquare = (float)dwSumPhaseCurr[3] / (float)SAMPLE_COUNT_THRESHOLD;
        rms = sqrtf(avgSquare) * calib_curr / 10000;
        primary.RMS_Curr_Phase_R = (float)rms;
        dwSumPhaseCurr[3] = 0;

        avgSquare = (float)dwSumPhaseCurr[4] / (float)SAMPLE_COUNT_THRESHOLD;
        rms = sqrtf(avgSquare) * calib_curr / 10000;
        primary.RMS_Curr_Phase_Y = (float)rms;
        dwSumPhaseCurr[4] = 0;

        avgSquare = (float)dwSumPhaseCurr[5] / (float)SAMPLE_COUNT_THRESHOLD;
        rms = sqrtf(avgSquare) * calib_curr / 10000;
        primary.RMS_Curr_Phase_B = (float)rms;
        dwSumPhaseCurr[5] = 0;

        avgSquare = (float)dwSumPhaseCurr[6] / (float)SAMPLE_COUNT_THRESHOLD;
        rms = sqrtf(avgSquare) * calib_curr / 10000;
        system_para.Ground_current = (unsigned int)rms;
        dwSumPhaseCurr[6] = 0;

        /*
         * RMS Calculation of the Input and Output Voltage
         */
        avgSquare = (float)dwSumPhaseVolt[0] / (float)SAMPLE_COUNT_THRESHOLD;
        rms = sqrtf(avgSquare) * calib_sec / 10000;
        secondary.L2N_Volt_Phase_R = (unsigned int)rms;
        dwSumPhaseVolt[0] = 0;

        avgSquare = (float)dwSumPhaseVolt[1] / (float)SAMPLE_COUNT_THRESHOLD;
        rms = sqrtf(avgSquare) * calib_sec / 10000;
        secondary.L2N_Volt_Phase_Y = (unsigned int)rms;
        dwSumPhaseVolt[1] = 0;

        avgSquare = (float)dwSumPhaseVolt[2] / (float)SAMPLE_COUNT_THRESHOLD;
        rms = sqrtf(avgSquare) * calib_sec / 10000;
        secondary.L2N_Volt_Phase_B = (unsigned int)rms;
        dwSumPhaseVolt[2] = 0;

        avgSquare = (float)dwSumPhaseVolt[3] / (float)SAMPLE_COUNT_THRESHOLD;
        rms = sqrtf(avgSquare) * calib_pri / 10000;
        primary.L2L_Volt_Phase_RY = (unsigned int)rms;
        dwSumPhaseVolt[3] = 0;

        avgSquare = (float)dwSumPhaseVolt[4] / (float)SAMPLE_COUNT_THRESHOLD;
        rms = sqrtf(avgSquare) * calib_pri / 10000;
        primary.L2L_Volt_Phase_YB = (unsigned int)rms;
        dwSumPhaseVolt[4] = 0;

        avgSquare = (float)dwSumPhaseVolt[5] / (float)SAMPLE_COUNT_THRESHOLD;
        rms = sqrtf(avgSquare) * calib_pri / 10000;
        primary.L2L_Volt_Phase_BR = (unsigned int)rms;
        dwSumPhaseVolt[5] = 0;

        sampleCount = 0;
    }

    /*
     * Created a voltage buffer for instaneous power calcualtion
     */
    primary.Volt_buff[0] = primary.L2L_Volt_Phase_RY;
    primary.Volt_buff[1] = primary.L2L_Volt_Phase_YB;
    primary.Volt_buff[2] = primary.L2L_Volt_Phase_BR;

    secondary.Volt_buff[0] = secondary.L2N_Volt_Phase_R;
    secondary.Volt_buff[1] = secondary.L2N_Volt_Phase_Y;
    secondary.Volt_buff[2] = secondary.L2N_Volt_Phase_B;


    /*
     * Need to the logic for the Frequency Calculation
     */

    if((last_sample_R < 0 && wAdcVoltBuff[0] >= 0))
    {
        lasttimestamp_R = currenttimestamp_R;
        currenttimestamp_R = currenttimestamp_R;
        dww_Frequency_Calculation();
    }

    if((last_sample_Y < 0 && wAdcVoltBuff[1] >= 0))
    {
        lasttimestamp_Y = currenttimestamp_Y;
        currenttimestamp_Y = currenttimestamp_R;
    }

    last_sample_R = wAdcVoltBuff[0];
    last_sample_Y = wAdcVoltBuff[1];
    last_sample_B = wAdcVoltBuff[2];
    /*
     * END of the logic for the frequency
     */


    //
    // Clear the ADC interrupt flags.
    //
    ADC_clearInterruptStatus(myADC0_BASE, ADC_INT_NUMBER1);
    ADC_clearInterruptStatus(myADC1_BASE, ADC_INT_NUMBER1);

    if(ADC_getInterruptOverflowStatus(myADC0_BASE, ADC_INT_NUMBER1))
    {
        ADC_clearInterruptOverflowStatus(myADC0_BASE, ADC_INT_NUMBER1);
        ADC_clearInterruptStatus(myADC0_BASE, ADC_INT_NUMBER1);
    }

    if(ADC_getInterruptOverflowStatus(myADC1_BASE, ADC_INT_NUMBER1))
    {
        ADC_clearInterruptOverflowStatus(myADC1_BASE, ADC_INT_NUMBER1);
        ADC_clearInterruptStatus(myADC1_BASE, ADC_INT_NUMBER1);
    }

    Interrupt_clearACKGroup(INT_myADC0_1_INTERRUPT_ACK_GROUP);
}

/*
 *Logic added calculating the Frequency
 *
 */
void dww_Frequency_Calculation()
{


    currenttimestamp_R = CPUTimer_getTimerCount(Cputimer_BASE);

    if (lasttimestamp_R != 0)
    {
        timediff = lasttimestamp_R - currenttimestamp_R;
        timeperiod = timediff/ 150000000.0;

        if(timeperiod > 0)
        {
            frequency = 1.0 / timeperiod;
        }

    }

    lasttimestamp_R = currenttimestamp_R;
    primary.Freq_R_Phase = primary.Freq_B_Phase = primary.Freq_Y_Phase = frequency;
    secondary.Freq_R_Phase = secondary.Freq_Y_Phase = secondary.Freq_B_Phase = frequency;
}

/*
 * This Function includes the following Calculations:
 * 1. Primary Line to Neutral calculation
 * 2. Primary Average Current
 * 3. Primary Average Voltage
 * 4. Primary Neutral Current
 * 5. Primary KVA
 * 6. Primary KVAR
 */
void dww_Pri_Sec_Calculation(unsigned int reg)
{
    unsigned int dwCurrSqr;
    unsigned int dwCurrSum;

    switch(reg)
    {
    case PRIMARY:
    {
        /*
         * Calculation to convert the L2L voltage to L2N Voltage for Input
         */
        primary.L2N_Volt_Phase_R = (primary.L2L_Volt_Phase_RY / 1.7320);
        primary.L2N_Volt_Phase_Y = (primary.L2L_Volt_Phase_YB / 1.7320);
        primary.L2N_Volt_Phase_B = (primary.L2L_Volt_Phase_BR / 1.7320);

        /*
         * Calculation for the Primary Average Current
         */
        primary.RMS_Avg_Curr = ((primary.RMS_Curr_Phase_R + primary.RMS_Curr_Phase_Y + primary.RMS_Curr_Phase_B) / 3);

        /*
         * Calculation for the Primary Average Voltage
         */
        primary.RMS_Avg_Volt = ((primary.L2L_Volt_Phase_RY + primary.L2L_Volt_Phase_YB + primary.L2L_Volt_Phase_BR) / 3);

        /*
         * Calculation for the Primary Neutral Current
         */
        dwCurrSqr = (primary.RMS_Curr_Phase_R * primary.RMS_Curr_Phase_R) +
                    (primary.RMS_Curr_Phase_Y * primary.RMS_Curr_Phase_Y) +
                    (primary.RMS_Curr_Phase_B * primary.RMS_Curr_Phase_B);
        dwCurrSum = (primary.RMS_Curr_Phase_R * primary.RMS_Curr_Phase_Y) +
                    (primary.RMS_Curr_Phase_R * primary.RMS_Curr_Phase_B) +
                    (primary.RMS_Curr_Phase_Y * primary.RMS_Curr_Phase_B);
        primary.Neutral_Current = sqrt(dwCurrSqr - dwCurrSum);

        break;
    }
    case SECONDARY:
    {
        /*
         * Calculation to convert L2N voltage to L2L Voltage for Output
         */
        //secondary.L2L_Volt_Phase_RY = (secondary.L2N_Volt_Phase_R * 1.7320);
        secondary.L2L_Volt_Phase_RY = (secondary.L2N_Volt_Phase_R * 1.7320);
        secondary.L2L_Volt_Phase_YB = (secondary.L2N_Volt_Phase_Y * 1.7320);
        secondary.L2L_Volt_Phase_BR = (secondary.L2N_Volt_Phase_B * 1.7320);

        /*
         * Calculation for the secondary Average Current
         */
        secondary.RMS_Avg_Curr = ((secondary.RMS_Curr_Phase_R + secondary.RMS_Curr_Phase_Y + secondary.RMS_Curr_Phase_B) / 3);

        /*
         * Calculation for the secondary Average Line to Line Voltage
         */
        secondary.RMS_Avg_Volt = ((secondary.L2L_Volt_Phase_RY + secondary.L2L_Volt_Phase_YB + secondary.L2L_Volt_Phase_BR) / 3);

        /*
         * Calculation for the secondary Average Line to Neutral Voltage
         */
        secondary.RMS_Avg_L2N_Volt = ((secondary.L2N_Volt_Phase_R + secondary.L2N_Volt_Phase_Y + secondary.L2N_Volt_Phase_B) / 3);

        /*
         * Calculation for the Crest factor
         */
        secondary.Crest_Factor_Phase_R = ((Peak_Current) / (secondary.RMS_Curr_Phase_R));
        secondary.Crest_Factor_Phase_Y = ((Peak_Current) / (secondary.RMS_Curr_Phase_Y));
        secondary.Crest_Factor_Phase_B = ((Peak_Current) / (secondary.RMS_Curr_Phase_B));

        /*
         * Calculation for the Secondary Neutral Current
         */
        dwCurrSqr = (secondary.RMS_Curr_Phase_R * secondary.RMS_Curr_Phase_R) +
                    (secondary.RMS_Curr_Phase_Y * secondary.RMS_Curr_Phase_Y) +
                    (secondary.RMS_Curr_Phase_B * secondary.RMS_Curr_Phase_B);
        dwCurrSum = (secondary.RMS_Curr_Phase_R * secondary.RMS_Curr_Phase_Y) +
                    (secondary.RMS_Curr_Phase_R * secondary.RMS_Curr_Phase_B) +
                    (secondary.RMS_Curr_Phase_Y * secondary.RMS_Curr_Phase_B);
        secondary.Neutral_Current = sqrt(dwCurrSqr - dwCurrSum);

        break;
    }
    }
}

